// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks   Task[]
  diaries Diary[]
  books   Books[]

  @@map("users")
}

enum PriorityType {
  PAIN_PREVENTION
  GAIN_PRODUCTION

  @@map("priority")
}

enum StatusType {
  PENDING
  DONE

  @@map("status")
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  title       String
  description String?      @db.Text
  priority    PriorityType
  date        DateTime
  status      StatusType
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("tasks")
}

enum MoodType {
  GOOD
  NEUTRAL
  BAD

  @@map("mood")
}

model Diary {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  date    DateTime
  content String?  @db.Text

  mood MoodType @default(NEUTRAL)

  workProductive Boolean @default(false)
  dayWasGood     Boolean @default(false)
  sleptWell      Boolean @default(false)
  keptPromises   Boolean @default(false)
  exercised      Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("diaries")
}

enum BookStatus {
  WANT_TO_READ
  READ
  READING
}

model Books {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  externalId String?
  title      String
  author     String?
  thumbnail  String?    @db.Text
  status     BookStatus @default(WANT_TO_READ)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@map("books")
}
